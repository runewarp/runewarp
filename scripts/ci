#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "lib/runewarp"

Runewarp::Core.run_cli do
  repo_root = File.expand_path("..", __dir__)
  Dir.chdir(repo_root) do
    Runewarp::Core.section("Linting workflows")
    Runewarp::Shell.run!("./scripts/lint-workflows")

    Runewarp::Core.section("Running Ruby automation tests")
    Runewarp::Shell.run!("./scripts/test-automation")

    Runewarp::Core.section("Checking release metadata")
    Runewarp::Shell.run!("./scripts/validate-release-metadata", "ci")

    Runewarp::Core.section("Checking source install path")
    Runewarp::Shell.run!("./scripts/check-distribution", "cargo-install", "--bin-name", "runewarp", "--probe-arg", "--help", "--expected-text", "Usage: runewarp")

    Runewarp::Core.section("Checking package readiness")
    Runewarp::Shell.run!("./scripts/check-distribution", "package-readiness")

    Runewarp::Core.section("Checking Rust formatting")
    Runewarp::Shell.run!("cargo", "fmt", "--check")

    Runewarp::Core.section("Running Clippy")
    Runewarp::Shell.run!("cargo", "clippy", "--all-targets", "--", "-D", "warnings")

    Runewarp::Shell.run!("./scripts/audit-dependencies")

    Runewarp::Core.section("Running Rust tests")
    Runewarp::Shell.run!("cargo", "test", "--quiet")

    Runewarp::Core.section("Building documentation")
    Runewarp::Shell.run!("cargo", "doc", "--no-deps")

    Runewarp::Core.section("Running Docker example smoke")
    Runewarp::Shell.run!("./scripts/docker-example", "smoke")

    Runewarp::Core.section("Checking Docker image path")
    Runewarp::Shell.run!("./scripts/check-distribution", "docker-image", "--probe-arg", "--help", "--expected-text", "Usage: runewarp", "--image-tag", "runewarp:ci")

    Runewarp::Core.success("CI contract passed")
    Runewarp::Core.note("Release metadata, distribution checks, Rust checks, dependency advisory scan, docs, and Docker validation all succeeded")
  end
end
