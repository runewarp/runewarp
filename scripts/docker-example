#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "lib/runewarp"

def usage(message = "docker-example <prepare|smoke> [--image-ref IMAGE_REF]")
  Runewarp::Core.usage_error(message)
end

def example_dir
  File.expand_path("../examples/docker", __dir__)
end

def repo_root
  File.expand_path("..", __dir__)
end

def parse_optional_image_ref(arguments)
  return [nil, arguments] if arguments.empty?

  usage unless arguments.length == 2 && arguments.first == "--image-ref"
  [arguments.last, []]
end

def prepare_example(reset_requested:, image_ref:)
  Runewarp::DockerExample.prepare(example_dir: example_dir, repo_root: repo_root, reset_requested: reset_requested, image_ref: image_ref)
end

def smoke_example(image_ref:)
  Runewarp::DockerExample.smoke(example_dir: example_dir, repo_root: repo_root, image_ref: image_ref)
end

Runewarp::Core.run_cli do
  command = ARGV.shift

  case command
  when "prepare"
    reset_requested = ARGV.delete("--reset")
    image_ref, remaining = parse_optional_image_ref(ARGV)
    usage("docker-example <prepare|smoke> [--image-ref IMAGE_REF] [--reset]") unless remaining.empty?
    prepare_example(reset_requested: !!reset_requested, image_ref: image_ref)
  when "smoke"
    image_ref, remaining = parse_optional_image_ref(ARGV)
    usage unless remaining.empty?
    smoke_example(image_ref: image_ref)
  else
    usage
  end
end
